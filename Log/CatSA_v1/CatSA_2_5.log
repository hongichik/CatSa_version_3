====================================================================
CẤU HÌNH LÚC CHẠY (config_dir: config | version: catsa_2_5)
====================================================================
logging:
  dir: Log
  level: INFO
  console: true
project:
  name: CatSA_v1
  filename_mode: custom
  custom_filename: CatSA_2_5.log
wandb:
  enabled: true
  api_key: '***da-che***'
  project: ''
  entity: ''
  run_name: ''
  mode: online
dataset:
  source: kagglehub
  kagglehub_handle: retailrocket/ecommerce-dataset
  local_path: data/raw
  name: retailrocket
preprocess:
  output_dir: data/retailrocket_2_5
  train_file: train.txt
  val_file: val.txt
  test_file: test.txt
  lookup_file: lookup_tables.pkl
  event_types:
  - view
  session_same_day: true
  session_gap_seconds: 1800
  dedup_consecutive: false
  min_item_support: 5
  min_session_length: 2
  max_session_length: 5
  session_length_mode: filter
  max_prefix_length: 50
  require_item_category: false
  val_ratio: 0.1
  test_ratio: 0.1
  max_sessions: 0
data:
  data_dir: data/retailrocket_2_5
  train_file: train.txt
  val_file: val.txt
  test_file: test.txt
  lookup_file: lookup_tables.pkl
model:
  embedding_dim: 100
  num_layers: 2
  use_taxonomy: true
  dropout: 0.1
augment:
  strategies:
  - same
  - sibling
  - hybrid
  strategy_weights: []
  eta_aug: 0.3
  eta_crop: 0.75
  k_min: 5
training:
  use_cl: true
  lambda_cl: 0.1
  tau: 0.5
  batch_size: 100
  learning_rate: 0.001
  weight_decay: 1.0e-05
  max_epochs: 30
  patience: 5
  grad_clip: 5.0
  seed: 42
  device: auto
  num_workers: 0
  checkpoint_dir: checkpoints
  save_dir: checkpoints/CatSA_v1/catsa_v1/CatSA_2_5
evaluation:
  top_k:
  - 10
  - 20
  primary_metric: mrr@20
config_dir: config
version: catsa_2_5
